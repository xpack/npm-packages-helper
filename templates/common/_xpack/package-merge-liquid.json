{
  "name": "{{packageScopedName}}",
  "version": "{{packageVersion}}",
  "description": "{{packageDescription}}",

{%- if topConfig.isTypescript %}
  "type": "module",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
{%- if isNpmExecutable %}
  "bin": {
    "{{topConfig.programName}}": "./bin/{{topConfig.programName}}.js"
  },
{%- endif %}
{%- endif %}

  "scripts": {
    "generate-top-commons": "bash node_modules/@xpack/npm-packages-helper/maintenance-scripts/generate-top-commons.sh --xpack",

{%- if topConfig.isWebDeployOnly != true and packageVersion != '0.0.0' %}
    "prepare": "del-cli dist && npm run prettier && npm run lint && npm run compile",

  {%- if topConfig.useApiExtractor %}
    "api-extractor": "api-extractor run --local --verbose",
  {%- endif %}

  {%- if topConfig.isTypescript %}
    "compile-watch": "tsc --build --verbose --watch src",
    "compile": "tsc --project tsconfig.json",
    "fix-compile": "npm run prettier && npm run fix && npm run compile",
  {%- endif %}

  {%- if topConfig.usePrettier %}
    "prettier": "prettier src tests --write --config config/.prettierrc.json --ignore-path config/.prettierignore",
  {%- endif %}

  {%- if topConfig.isJavascript %}
      "fix": "standard --fix src tests",
      "dev-cycle": "npm run fix && npm run test",
  {%- elsif topConfig.isTypescript %}
    {%- if topConfig.useEslint %}
        "fix": "eslint --config config/eslint.config.js --fix src",
    {%- else %}
        "fix": "ts-standard --fix src tests && standard esm",
    {%- endif %}
      "dev-cycle": "npm run fix && npm run compile && npm run test",
  {%- endif %}

{%- endif %}

    "npm-install": "npm install",
    "npm-link-helpers": "npm link @xpack/npm-packages-helper @xpack/docusaurus-template-liquid",
    "npm-link": "npm link",
    "npm-outdated": "npm outdated",
    "npm-update": "npm update",

{%- if isNpmPublished %}
    "npm-pack": "npm pack",
    "postversion": "git push origin --all && git push origin --tags",
    "git-log": "git log --pretty='%cd * %h %s' --date=short",

  {%- if topConfig.isJavascript %}
      "lint": "standard src",
  {%- elsif topConfig.isTypescript %}
    {%- if topConfig.useEslint %}
        "lint": "eslint --config config/eslint.config.js src",
    {%- else %}
        "lint": "ts-standard src && standard esm",
    {%- endif %}
  {%- endif %}

  {%- if topConfig.isJavascript %}
      "prepare": "npm run lint",
  {%- elsif topConfig.isTypescript %}
      "prepare": "del-cli dist && npm run prettier && npm run lint && npm run compile",
  {%- endif %}

  {%- if topConfig.skipCiTests != true and packageVersion != '0.0.0' %}
      "pretest-coverage": "npm run lint",
      "pretest-no-coverage": "npm run lint",
    {%- if topConfig.useTap %}
        "test-coverage": "tap --show-full-coverage",
        "test-no-coverage": "tap --disable-coverage",
        "tap": "tap --reporter=tap",
        {% if topConfig.testCoverage != true %}"test": "npm run test-no-coverage",{% else %}"test": "npm run test-coverage",{% endif %}
    {%- elsif topConfig.useCustomTests %}
    {% else %}
        "test": "echo 'No tests defined'",
    {% endif %}
  {%- endif %}

    "prepublishOnly": "npm run lint && npm run test",
    "postpublish": "git push origin --follow-tags",
    "clean": "del-cli --force dist build .tap",
    "deep-clean": "npm run clean && del-cli --force node_modules package-lock.json",
{%- else %}
    "deep-clean": "del-cli --force node_modules package-lock.json",
{%- endif %}
    "npm-audit": "npm audit fix --force",

    "dumpconf": "env | sort | uniq",
    "show-versions": "echo $(which node) $(node --version) && echo $(which npm) $(npm --version)"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/{{githubProjectOrganization}}/{{githubProjectName}}.git"
  },
  "author": {
    "name": "Liviu Ionescu",
    "email": "ilg@livius.net",
    "url": "https://github.com/ilg-ul"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/{{githubProjectOrganization}}/{{githubProjectName}}/issues"
  },

{%- if topConfig.isWebPreview %}
  "homepage": "https://{{githubProjectOrganization}}.github.io/{{packageName}}/",
{%- if  packageName != githubProjectName %}
  "homepagePreview": "https://{{githubProjectOrganization}}.github.io/{{githubProjectName}}/",
{%- endif %}
{%- elsif topConfig.hasWebsite %}
{%- assign computedGithubProjectName = githubProjectOrganization | append: '.github.io' %}
{%- if githubProjectName == computedGithubProjectName %}
  "homepage": "https://{{githubProjectOrganization}}.github.io/",
{%- else %}
  "homepage": "https://{{githubProjectOrganization}}.github.io/{{githubProjectName}}/",
{%- endif %}
{%- else %}
  "homepage": "https://github.com/{{githubProjectOrganization}}/{{githubProjectName}}/",
{%- endif %}

 "$dependenciesUrls": { {% if topConfig.isTypescript %}
    "@tsconfig/node20": "https://www.npmjs.com/package/@tsconfig/node20",
    "@types/node": "https://www.npmjs.com/package/@types/node",{%- unless topConfig.skipCiTests %}
    "@types/tap": "https://www.npmjs.com/package/@types/tap",{% endunless %}{% endif %}
    "del-cli": "https://www.npmjs.com/package/del-cli",
    "json": "https://www.npmjs.com/package/json",
    "liquidjs": "https://www.npmjs.com/package/liquidjs"{%- if topConfig.isJavascript or topConfig.isTypescript %}{%- unless topConfig.skipCiTests %},
    "tap": "https://www.npmjs.com/package/tap"{% endunless %}{% endif %}{%- if topConfig.isTypescript %},
    "ts-node": "https://www.npmjs.com/package/ts-node"{%- if topConfig.useEslint %},
    "eslint": "https://www.npmjs.com/package/eslint",
    "@eslint/js": "https://www.npmjs.com/package/@eslint/js",
    "eslint-config-prettier": "https://www.npmjs.com/package/eslint-config-prettier",
    "typescript-eslint": "https://www.npmjs.com/package/typescript-eslint"{% endif %},
    "prettier": "https://www.npmjs.com/package/prettier",
    "typescript": "https://www.npmjs.com/package/typescript"{%- endif %}
  },
  "dependencies": {},
  "devDependencies": { {% if topConfig.isTypescript %}
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.9.0",{%- unless topConfig.skipCiTests %}
    "@types/tap": "^15.0.12",{% endunless %}{% endif %}
    "del-cli": "^7.0.0",
    "json": "^11.0.0",
    "liquidjs": "^10.27.0"{%- if topConfig.isJavascript or topConfig.isTypescript %}{%- unless topConfig.skipCiTests %},
    "tap": "^21.7.4"{% endunless %}{% endif %}{%- if topConfig.isTypescript %},
    "ts-node": "^10.9.2"{%- if topConfig.useEslint %},
    "eslint": "^9.39.4",
    "@eslint/js": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.59.4"{% endif %},
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"{%- endif %}
  },

  "engines": {
    "node": ">=20.0"
  }
}
